# Copy to .env for local dev. In docker-compose, DATABASE_URL/REDIS_URL are overridden
# to point at the postgres/redis containers - the values here are for running the app
# directly on the host (e.g. via `uvicorn app.main:app --reload` outside Docker).
ENVIRONMENT=development
DATABASE_URL=postgresql://app:app@localhost:5432/dia_del_nino
REDIS_URL=redis://localhost:6379/0

# Cloudflare R2 (S3-compatible). Endpoint looks like:
# https://<account_id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=changeme
R2_SECRET_ACCESS_KEY=changeme
R2_ENDPOINT_URL=https://changeme.r2.cloudflarestorage.com
R2_BUCKET_NAME=dia-del-nino-videos

# Generate with: python scripts/generate_secret.py
UPLOAD_TOKEN_SECRET=changeme
ADMIN_JWT_SECRET=changeme

# Generate with: python scripts/generate_admin_password_hash.py
ADMIN_PASSWORD_HASH=changeme

UPLOAD_TOKEN_TTL_SECONDS=1800
ADMIN_SESSION_TTL_SECONDS=28800

CORS_ALLOW_ORIGINS=http://localhost:3000
CORS_ALLOW_ORIGIN_REGEX=https://.*\.vercel\.app

RATE_LIMIT_SUBMIT=5/hour
RATE_LIMIT_CONFIRM_UPLOAD=20/hour
RATE_LIMIT_ADMIN_LOGIN=5/minute
RATE_LIMIT_VOTE=10/hour

SERVER_VALIDATION_FAILURE_STATUS=rejected
PENDING_UPLOAD_EXPIRY_SECONDS=3600

# Salesforce Marketing Cloud sync - off until real credentials exist. Leave
# SFMC_ENABLED=false (or unset) and the rest can stay blank; nothing else breaks.
SFMC_ENABLED=false
SFMC_SUBDOMAIN=
SFMC_CLIENT_ID=
SFMC_CLIENT_SECRET=
SFMC_ACCOUNT_ID=
SFMC_DATA_EXTENSION_KEY=
# External Key of the sendable "adults" DE used for the voting stage (Cedula_Adulto as PK)
SFMC_ADULTS_DATA_EXTENSION_KEY=
